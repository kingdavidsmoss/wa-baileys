# Puerto del servidor HTTP (para Postman / API)
PORT=3000

# Clave de acceso a la API (header x-api-key). Genera una con: openssl rand -hex 32
API_KEY=cambia-esto-por-una-clave-segura

# Máximo de peticiones por minuto por IP (protege tu número de baneo por spam)
RATE_LIMIT_MAX=20

# Lada del país. Con 521 solo necesitas escribir 10 dígitos al enviar mensajes.
# México celular = 521 | México fijo = 52 | USA/Canada = 1
LADA=521

# ID del grupo destino (obténlo ejecutando listarGrupos). Ej: 120363XXXXXXXXXX@g.us
GROUP_ID=

# Número de prueba (solo 10 dígitos, la lada se agrega automáticamente)
NUMERO_PRUEBA=1234567890
